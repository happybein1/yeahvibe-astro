---
import type { Props } from '@astrojs/starlight/props';
import Default from '@astrojs/starlight/components/Head.astro';

const { entry, lang } = Astro.props;

const siteUrl = 'https://www.yeahvibe.com';
const currentPath = Astro.url.pathname;
const currentUrl = new URL(currentPath, siteUrl).toString();
const ogImage = `${siteUrl}/og-image.jpg`;
const isFr = lang === 'fr';

// Safely read entry data — entry can be undefined on splash/404 pages
const title = entry?.data?.title ?? 'YeahVibe';
const description = entry?.data?.description ?? (isFr
  ? 'Prenez de meilleures décisions avec YeahVibe — pratiques, outils et cadres pour individus et organisations.'
  : 'Make better decisions with YeahVibe — practical frameworks, best practices and tools for individuals and organizations.');

// Build hreflang URLs
const enUrl = currentUrl.replace('/fr/', '/').replace(/\/fr$/, '/');
const frUrl = currentPath.startsWith('/fr')
  ? currentUrl
  : `${siteUrl}/fr${currentPath === '/' ? '/' : currentPath}`;
---
<Default {...Astro.props} />

<!-- Canonical -->
<link rel="canonical" href={currentUrl} />

<!-- Hreflang -->
<link rel="alternate" hreflang="en" href={enUrl} />
<link rel="alternate" hreflang="fr" href={frUrl} />
<link rel="alternate" hreflang="x-default" href={enUrl} />

<!-- Open Graph -->
<meta property="og:title" content={title} />
<meta property="og:description" content={description} />
<meta property="og:url" content={currentUrl} />
<meta property="og:type" content="website" />
<meta property="og:image" content={ogImage} />
<meta property="og:locale" content={isFr ? 'fr_FR' : 'en_US'} />
<meta property="og:locale:alternate" content={isFr ? 'en_US' : 'fr_FR'} />
<meta property="og:site_name" content="YeahVibe" />

<!-- Twitter Card -->
<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:title" content={title} />
<meta name="twitter:description" content={description} />
<meta name="twitter:image" content={ogImage} />

<!-- Robots -->
<meta name="robots" content="index, follow" />
<meta name="author" content="YeahVibe" />

<!-- Google Analytics -->
<script async src="https://www.googletagmanager.com/gtag/js?id=G-TXTCCH1ZGY"></script>
<script>
  window.dataLayer = window.dataLayer || [];
  function gtag(){dataLayer.push(arguments);}
  gtag('js', new Date());
  gtag('config', 'G-TXTCCH1ZGY');
</script>

<!-- Language auto-detection (root only) + preference storage -->
<script>
  (function() {
    // Store preference when browsing /fr/
    if (window.location.pathname.startsWith('/fr')) {
      localStorage.setItem('yv-lang', 'fr');
      return;
    }
    // Only auto-redirect from exact root
    if (window.location.pathname !== '/') return;
    const stored = localStorage.getItem('yv-lang');
    if (stored === 'fr') { window.location.replace('/fr/'); return; }
    if (stored === 'en') return;
    // First visit: check browser language
    const lang = (navigator.language || 'en').toLowerCase();
    if (lang.startsWith('fr')) {
      localStorage.setItem('yv-lang', 'fr');
      window.location.replace('/fr/');
    }
  })();
</script>

<!-- JSON-LD Structured Data -->
<script type="application/ld+json" set:html={JSON.stringify({
  "@context": "https://schema.org",
  "@type": "WebSite",
  "name": "YeahVibe",
  "url": siteUrl,
  "description": "Decision-making frameworks, personal effectiveness tools and societal insights — in English and French.",
  "inLanguage": ["en", "fr"],
  "potentialAction": {
    "@type": "SearchAction",
    "target": `${siteUrl}/search?q={search_term_string}`,
    "query-input": "required name=search_term_string"
  }
})} />
